# ShieldOps Backend - Environment Variables

# Security
SECRET_KEY=your-secret-key-here

# CORS - домены фронтенда (через запятую)
CORS_ORIGINS=["http://localhost:5173", "https://your-frontend.vercel.app"]

# Database
POSTGRES_USER=shieldops
POSTGRES_PASSWORD=shieldops
POSTGRES_DB=shieldops
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# App
APP_NAME=ShieldOps API
API_PREFIX=/api/v1
ENVIRONMENT=development
DEBUG=true
