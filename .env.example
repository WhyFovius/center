# ShieldOps Production Environment Variables
# Скопируй этот файл в .env и заполни значения

# Database (Supabase/Neon)
DATABASE_URL=postgresql://user:password@host:port/db
POSTGRES_USER=zeroday
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=zeroday
POSTGRES_HOST=your-db-host.supabase.co
POSTGRES_PORT=5432

# Security
SECRET_KEY=your-super-secret-key-here-generate-with-python-secrets

# Redis (Upstash)
REDIS_URL=redis://default:password@host:port
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# OpenRouter (AI Generation)
OPENROUTER_API_KEY=

# App Settings
ENVIRONMENT=production
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=1440
