# Frontend Environment Variables
# При моно-деплое API находится на том же домене

# Для локальной разработки:
# VITE_API_URL=http://localhost:8000/api/v1

# Для production (Vercel):
VITE_API_URL=/api/v1

# OpenRouter API ключ для AI-генерации сценариев
# Получить: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Модель для AI (бесплатные модели)
VITE_OPENROUTER_MODEL=qwen/qwen3.6-plus:free
